# ============================================================
# NEWS_BOT_HEX - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# ============================================================
# WordPress Configuration
# ============================================================
# WordPress hosting API base URL
WP_HOSTING_API_BASE=https://api.yoursite.com
# JWT token for WordPress API authentication (auto-refreshed, can leave empty)
WP_HOSTING_JWT_TOKEN=
# WordPress username for token refresh
WP_USER=your_wordpress_username
# WordPress application password
WP_PASSWORD=your_wordpress_app_password
# Default image URL for fallback images
WP_DEFAULT_IMAGE_URL=https://api.yoursite.com/image-310/
# Your WordPress site URL
WP_SITE_URL=https://yoursite.com
# Default category for articles
WP_DEFAULT_CATEGORY=Noticias
# Default image endpoint
WP_DEFAULT_IMAGE_ENDPOINT=/image-310/

# ============================================================
# Facebook Configuration
# ============================================================
# Facebook Page ID
FACEBOOK_PAGE_ID=your_page_id
# Facebook Page Access Token
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token
# Facebook App ID
FACEBOOK_APP_ID=your_app_id
# Facebook App Secret
FACEBOOK_APP_SECRET=your_app_secret
# Facebook Graph API version
FACEBOOK_GRAPH_API_VERSION=v23.0
# Facebook Graph API base URL
FACEBOOK_GRAPH_API_BASE=https://graph.facebook.com

# ============================================================
# Bluesky Configuration
# ============================================================
# Bluesky handle (e.g., yourhandle.bsky.social)
BLUESKY_HANDLE=your_handle.bsky.social
# Bluesky app password
BLUESKY_APP_PASSWORD=your_app_password
# Bluesky PDS URL
BLUESKY_PDS_URL=https://bsky.social

# ============================================================
# Mastodon Configuration
# ============================================================
# Mastodon instance URL
MASTODON_INSTANCE_URL=https://mastodon.social
# Mastodon access token
MASTODON_ACCESS_TOKEN=your_access_token
# Mastodon API base (leave empty to auto-derive from instance URL)
MASTODON_API_BASE=

# ============================================================
# Unsplash Configuration
# ============================================================
# Unsplash access key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
# Unsplash API URL
UNSPLASH_API_URL=https://api.unsplash.com/search/photos
# Image orientation (landscape, portrait, squarish)
UNSPLASH_ORIENTATION=landscape
# Number of images per request
UNSPLASH_PER_PAGE=3

# ============================================================
# Google Images Configuration
# ============================================================
# Google Search API key
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
# Google Custom Search Engine ID
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id
# Google API URL
GOOGLE_API_URL=https://www.googleapis.com/customsearch/v1

# ============================================================
# Social Media Post Limits (characters)
# ============================================================
X_POST_LIMIT=260
BLUESKY_POST_LIMIT=250
MASTODON_POST_LIMIT=450

# ============================================================
# AI Model Configuration
# ============================================================
# Default AI provider (openrouter, gemini, local, mock)
AI_PROVIDER=openrouter
# Gemini model name
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# OpenRouter model
OPENROUTER_MODEL=openrouter/free
# OpenRouter API URL
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# OpenRouter auth URL
OPENROUTER_AUTH_URL=https://openrouter.ai/api/v1/auth/key
# OpenRouter referer
OPENROUTER_REFERER=http://yoursite.com
# OpenRouter app title
OPENROUTER_APP_TITLE=news_bot
# Whisper model for transcription
WHISPER_MODEL=medium

# ============================================================
# Local Model Configuration
# ============================================================
# Path to local GGUF model
LOCAL_MODEL_PATH=/path/to/models/qwen2-7b-q4_k_m.gguf
# Model context size
LOCAL_MODEL_N_CTX=3072
# Number of GPU layers
LOCAL_MODEL_N_GPU_LAYERS=26
# Batch size
LOCAL_MODEL_N_BATCH=64

# ============================================================
# External Models Location (for Docker volume mounts)
# ============================================================
# External directory where models are stored (e.g. /mnt/DATA1_256GB/llama-models)
# In Docker, this is mounted via: ${MODELS_LOCATION}:/app/models
MODELS_LOCATION=/path/to/external/models

# ============================================================
# Fake News Detection (Classic ML - TF-IDF + LogisticRegression)
# ============================================================
# Pre-trained model directory: models/news_validator/news_validator.pkl
# Falls back to heuristic rules if no model found

# ============================================================
# Model Parameters (General)
# ============================================================
MODEL_N_CTX=3072
MODEL_N_GPU_LAYERS=26
MODEL_N_BATCH=64
MODEL_MAX_TOKENS_TWEET=120
MODEL_MAX_TOKENS_THREAD=300
MODEL_TEMPERATURE=0.35
MODEL_TOP_P=0.9
MODEL_TOP_K=40
MODEL_REPEAT_PENALTY=1.15

# ============================================================
# Article Generation Parameters
# ============================================================
ARTICLE_MAX_TOKENS=1024
ARTICLE_TEMPERATURE=0.6
ARTICLE_TOP_P=0.9
ARTICLE_TOP_K=40
ARTICLE_REPETITION_PENALTY=1.2
ARTICLE_PRESENCE_PENALTY=0.6

# ============================================================
# Thread generation Parameters
# ============================================================
THREAD_TEMPERATURE=0.4
THREAD_TOP_P=0.9
THREAD_TOP_K=50
THREAD_MAX_TOKENS=1500

# ============================================================
# Gemini Configuration
# ============================================================
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.9
GEMINI_MAX_OUTPUT_TOKENS=5000
GEMINI_ENABLE_COST_TRACKING=true
GEMINI_MAX_COST_PER_MONTH_EUR=5.0
GEMINI_TIMEOUT=30
GEMINI_RETRY_ATTEMPTS=2

# ============================================================
# API Keys
# ============================================================
# NewsAPI key
NEWSAPI_KEY=your_newsapi_key
# Census API key
CENSUS_API_KEY=your_census_api_key
# Grok API key
GROK_API_KEY=your_grok_api_key
# X (Twitter) API credentials
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret
X_BEARER_TOKEN=your_x_bearer_token
# OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_api_key
# Gemini API key
GEMINI_API_KEY=your_gemini_api_key
# Groq API key (for Whisper transcription)
GROQ_API_KEY=your_groq_api_key
# Web Search for article enrichment (at least one required)
SERPER_API_KEY=your_serper_api_key
TAVILY_API_KEY=your_tavily_api_key

# ============================================================
# News API Configuration
# ============================================================
# Comma-separated list of sources to exclude
NEWS_EXCLUDE_SOURCES=el-mundo,el-pais,abc-news-es,la-vanguardia,20-minutos,marca,as,sport,news24
# News query
NEWS_QUERY=
# Page size for news fetching
NEWS_PAGE_SIZE=50
# Page number
NEWS_PAGE=1
# Comma-separated keywords for news filtering
NEWS_KEYWORDS=news,update,international,world,crisis,conflict,violence,economy,politics,population,regulation,wildlife,marine,murder,attack,stock,futures

# ============================================================
# Trusted Sources (comma-separated)
# ============================================================
TRUSTED_SOURCES=AP News,Reuters,Bloomberg.com,BBC News,NBC News

# ============================================================
# Copyright Risk Domains (comma-separated)
# ============================================================
COPYRIGHT_DOMAINS=elpais.com,elmundo.es,20minutos.es,marca.com,as.com,cincodias.elpais.es,bbc.com
VIDEO_COPYRIGHT_DOMAINS=youtube.com,youtu.be,tiktok.com,instagram.com,spotify.com,apple.com

# ============================================================
# Video Configuration (comma-separated domains)
# ============================================================
ALLOWED_VIDEO_DOMAINS=facebook.com,twitter.com,youtube.com

# ============================================================
# Cache Configuration (hours)
# ============================================================
CACHE_MAX_AGE_HOURS=6
CACHE_CLEANUP_MAX_AGE_HOURS=72

# ============================================================
# Retry Configuration
# ============================================================
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=2.0
RETRY_MAX_DELAY=60.0

# ============================================================
# Topic Normalization
# ============================================================
TOPIC_AUDIO=Noticias
TOPIC_PODCAST=Noticias
TOPIC_VIDEO=Noticias
TOPIC_POLITICA=Noticias
TOPIC_POLITICA_INTERNACIONAL=Noticias

# ============================================================
# Jina Reader Configuration
# ============================================================
JINA_API_URL=https://r.jina.ai/
JINA_API_KEY=your_jina_api_key

# ============================================================
# MongoDB Configuration
# ============================================================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB_NAME=news_bot
USE_MONGODB=true

# ============================================================
# Translation Configuration
# ============================================================
DEEP_TRANSLATOR_TARGET_LANG=es
DEEP_TRANSLATOR_SOURCE_LANG=en

# ============================================================
# Spell Checker Language
# ============================================================
SPELL_CHECKER_LANG=es

# ============================================================
# TTS (Text-to-Speech) Configuration
# ============================================================
# Modo TTS: "speaches" (Kokoro) o "coqui"
TTS_MODE=speaches

# --- Configuración para Speaches (Kokoro) ---
TTS_API_URL=http://localhost:5005
TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX-int8
TTS_VOICE=ef_dora
TTS_TIMEOUT=120

# --- Configuración para Coqui TTS ---
COQUI_API_URL=http://localhost:5002
COQUI_VOICE=es-ml-onyx
COQUI_MODEL=coqui-ai/tts

# ============================================================
# Audio Converter (ffmpeg) Configuration
# ============================================================
# URL del servicio de conversión de audio (ffmpeg API)
FFMPEG_API_URL=http://localhost:8082
